{
  "name": "octopus",
  "version": "0.1.0",
  "description": "桌面宠物：实时盯 Claude Code 等 coding agent 的状态、消息、授权与花费",
  "main": "main.js",
  "license": "MIT",
  "author": "myunwang",
  "scripts": {
    "start": "electron .",
    "install:hooks": "node backend/hookinstall.js",
    "uninstall:hooks": "node backend/hookinstall.js --uninstall",
    "meter:rebuild": "node backend/meter-rebuild.js",
    "package:mac": "bash scripts/package-mac.sh",
    "package:win": "electron-builder --win",
    "test": "node test/smoke.js && node test/state-smoke.js && node test/pricing.js && node test/territory.js && node test/codex-watch.js"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.myunwang.octopus",
    "productName": "Octopus",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "backend/**",
      "renderer/**",
      "assets/**",
      "shared/**",
      "hook/**"
    ],
    "win": {
      "target": ["nsis", "zip"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
