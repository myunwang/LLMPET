{
  "name": "octopus",
  "version": "0.1.0",
  "description": "桌面宠物：实时盯 Claude Code 等 coding agent 的状态、消息、授权与花费",
  "main": "main.js",
  "license": "MIT",
  "author": "myunwang",
  "scripts": {
    "start": "electron .",
    "install:hooks": "node backend/hookinstall.js",
    "uninstall:hooks": "node backend/hookinstall.js --uninstall",
    "meter:rebuild": "node backend/meter-rebuild.js",
    "package:mac": "bash scripts/package-mac.sh",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "test": "node test/smoke.js && node test/state-smoke.js && node test/pricing.js && node test/territory.js",
    "test:windows": "node test/windows-adapt.js"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "sharp": "^0.35.3"
  },
  "dependencies": {
    "png-to-ico": "^3.0.2"
  }
}
